
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your_google_places_key_here

# Chave da API da Anthropic (para o assistente "Posso Doar?")
# Obtenha em: https://console.anthropic.com
# ATENÇÃO: esta chave fica visível no bundle do app (MVP). Em produção, use um proxy backend.
EXPO_PUBLIC_ANTHROPIC_KEY=your_anthropic_key_here

# Ambiente (development | production)
EXPO_PUBLIC_APP_ENV=development
